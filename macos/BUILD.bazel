genrule(
    name = "StampedInfoPlist",
    srcs = ["Info.plist"],
    outs = ["Info-stamped.plist"],
    cmd = """
        VERSION=$$(grep STABLE_VERSION bazel-out/stable-status.txt | cut -d' ' -f2)
        BUILD_NUM=$$(grep STABLE_BUILD_NUMBER bazel-out/stable-status.txt | cut -d' ' -f2)
        /usr/libexec/PlistBuddy -c "Clear dict" $@
        /usr/libexec/PlistBuddy -c "Merge $(location Info.plist)" $@
        /usr/libexec/PlistBuddy -c "Add :CFBundleShortVersionString string $$VERSION" $@
        /usr/libexec/PlistBuddy -c "Add :CFBundleVersion string $$BUILD_NUM" $@
    """,
    stamp = True,
)

macos_application(
    name = "Durian",
    app_icons = select({
        ":ci": [],
        ":release": glob(["durian/AppIcon.icon/**"]),
        "//conditions:default": glob(["durian/AppIcon-Debug.icon/**"]),
    }),
    bundle_id = select({
        ":release": "org.js-lab.durian",
        "//conditions:default": "org.js-lab.durian.nightly",
    }),
    bundle_name = select({
        ":release": "Durian",
        "//conditions:default": "DurianNightly",
    }),
    entitlements = "durian/Durian.entitlements",
    infoplists = [":StampedInfoPlist"],
    minimum_os_version = "26.0",
    resources = ["//schema:pkl_schemas"] + select({
        ":ci": glob(["durian/CompiledIcons/release/**"]),
        "//conditions:default": [],
    }),
    deps = [":durian_lib"],
)
