/// Durian contact groups schema.
/// Usage: import "modulepath:/Groups.pkl" as G
module schema.Groups

class GroupEntry {
  description: String?
  /// Members list. Each entry is either a single email string or
  /// a list of strings (same person, multiple addresses).
  /// pkl-go receives this as interface{} for flexible normalization in Go.
  members: Listing<Any>
}
