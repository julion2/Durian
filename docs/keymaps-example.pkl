// Durian Keymaps Configuration
// Copy to ~/.config/durian/keymaps.pkl
// These are the defaults. Only include keymaps you want to change.
//
// All vim-style keybindings are fully configurable.
// sequence = true  : multi-key sequence (e.g. "gg", "dd", "gi")
// supports_count   : accepts count prefix (e.g. "5j" = move down 5)
// modifiers        : { "cmd" }, { "ctrl" }, { "shift" }, or omit for none
// context          : "list" (default), "search", "tag_picker", "thread", "compose_normal"

global_settings {
  keymaps_enabled = true
  show_keymap_hints = true
  sequence_timeout = 1.0              // seconds to wait for next key in sequence
}

keymaps {
  // ── Navigation ─────────────────────────────────────────────
  new { action = "next_email";  key = "j";  description = "Next email";     supports_count = true }
  new { action = "prev_email";  key = "k";  description = "Previous email"; supports_count = true }
  new { action = "first_email"; key = "gg"; description = "First email";    sequence = true }
  new { action = "last_email";  key = "G";  description = "Last email" }
  new { action = "page_down";   key = "d";  description = "Half-page down"; modifiers { "ctrl" }; supports_count = true }
  new { action = "page_up";     key = "u";  description = "Half-page up";   modifiers { "ctrl" }; supports_count = true }

  // ── Actions ────────────────────────────────────────────────
  new { action = "archive";      key = "a";  description = "Archive email" }
  new { action = "delete";       key = "dd"; description = "Delete email"; sequence = true }
  new { action = "toggle_read";  key = "u";  description = "Toggle read/unread" }
  new { action = "toggle_star";  key = "s";  description = "Toggle pin/star" }
  new { action = "tag_picker";   key = "t";  description = "Open tag picker" }

  // ── Tag Operations (configurable tag shortcuts) ────────────
  // tag_op applies +/- tag operations defined in the "tags" field.
  new { action = "tag_op"; key = "T"; tags = "+todo -inbox";    description = "Mark as todo" }
  new { action = "tag_op"; key = "W"; tags = "+waiting -inbox"; description = "Mark as waiting" }

  // ── Compose ────────────────────────────────────────────────
  new { action = "compose";   key = "c"; description = "Compose new email" }
  new { action = "reply";     key = "r"; description = "Reply" }
  new { action = "reply_all"; key = "R"; description = "Reply all" }
  new { action = "forward";   key = "f"; description = "Forward" }

  // ── Folder Navigation ──────────────────────────────────────
  new { action = "go_inbox";   key = "gi"; sequence = true; description = "Go to inbox" }
  new { action = "go_sent";    key = "gs"; sequence = true; description = "Go to sent" }
  new { action = "go_drafts";  key = "gd"; sequence = true; description = "Go to drafts" }
  new { action = "go_archive"; key = "ga"; sequence = true; description = "Go to archive" }

  // ── Search & UI ────────────────────────────────────────────
  new { action = "search";       key = "/";      description = "Search emails" }
  new { action = "close_detail"; key = "q";      description = "Close/back" }
  new { action = "reload_inbox"; key = "r";      description = "Reload inbox"; modifiers { "cmd" } }

  // ── Selection (Visual Mode) ────────────────────────────────
  new { action = "enter_visual_mode"; key = "v";      description = "Enter visual mode" }
  new { action = "enter_toggle_mode"; key = "V";      description = "Enter toggle visual mode" }
  new { action = "toggle_selection";  key = " ";      description = "Toggle current email" }
  new { action = "exit_visual_mode";  key = "Escape"; description = "Exit visual mode" }

  // ── Search Popup (context = "search") ──────────────────────
  new { action = "select_next"; key = "j"; modifiers { "ctrl" }; context = "search"; description = "Next result" }
  new { action = "select_prev"; key = "k"; modifiers { "ctrl" }; context = "search"; description = "Previous result" }

  // ── Tag Picker (context = "tag_picker") ────────────────────
  new { action = "select_next"; key = "j"; modifiers { "ctrl" }; context = "tag_picker"; description = "Next tag" }
  new { action = "select_prev"; key = "k"; modifiers { "ctrl" }; context = "tag_picker"; description = "Previous tag" }

  // ── Compose Vim Mode (context = "compose_normal") ──────────
  new { action = "exit_insert"; key = "jk"; sequence = true; context = "compose_normal"; description = "Exit insert mode" }

  // ── Thread View (context = "thread") ───────────────────────
  new { action = "enter_thread"; key = "l"; description = "Enter thread view" }
  new { action = "scroll_down";  key = "j"; context = "thread"; supports_count = true; description = "Scroll down" }
  new { action = "scroll_up";    key = "k"; context = "thread"; supports_count = true; description = "Scroll up" }
  new { action = "next_message"; key = "n"; context = "thread"; supports_count = true; description = "Next message" }
  new { action = "prev_message"; key = "N"; context = "thread"; supports_count = true; description = "Previous message" }
  new { action = "close_detail"; key = "h"; context = "thread"; description = "Back to email list" }
  new { action = "reply";        key = "r"; context = "thread"; description = "Reply to email" }
}
